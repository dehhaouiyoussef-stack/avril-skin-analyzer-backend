# ============================================================
# FICHIER DE CONFIGURATION - AGENT AVRIL WHATSAPP
# ============================================================
# IMPORTANT: Copiez ce fichier en ".env" et remplissez les valeurs
# Ne partagez JAMAIS ce fichier .env avec personne !

# ---- CLE API ANTHROPIC (pour Claude / l'intelligence artificielle) ----
# Obtenir sur: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-votre-cle-ici

# ---- CONFIGURATION WHATSAPP META ----
# Obtenir sur: https://developers.facebook.com/

# Token d'accès permanent WhatsApp (section "WhatsApp > Configuration")
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxx

# ID du numéro de téléphone WhatsApp Business
# (visible dans "WhatsApp > Configuration > Numéros de téléphone")
PHONE_NUMBER_ID=123456789012345

# Token de vérification que VOUS choisissez (n'importe quelle phrase secrète)
# Ce même token doit être entré dans Meta lors de la configuration du webhook
VERIFY_TOKEN=mon_token_secret_avril_2024

# ---- PORT DU SERVEUR (ne pas modifier) ----
PORT=5000
